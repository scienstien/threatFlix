# Google Gemini API Key (required for AI analysis)
GEMINI_API_KEY=your-gemini-api-key-here

# Server Configuration
PORT=8000

# Database
DATABASE_PATH=./data/threatflix.db

# Admin credentials (for hackathon demo)
