# Required security configuration
JWT_SECRET=replace-with-a-long-random-secret

# Server and local persistence
PORT=8000
DATABASE_PATH=./data/threatflix.db

# Optional runtime UEBA scoring sidecar
ML_SERVICE_URL=http://127.0.0.1:8001
ML_SERVICE_TIMEOUT_MS=2000

# Optional local Ollama interpretation layer
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3n:e2b
OLLAMA_REPORT_TIMEOUT_MS=120000
OLLAMA_CHAT_TIMEOUT_MS=60000
OLLAMA_KEEP_ALIVE=10m

# Post-detection graph similarity
GRAPH_SIMILARITY_ENABLED=true
GRAPH_SIMILARITY_MAX_CANDIDATES=500
GRAPH_SIMILARITY_API_DEFAULT_LIMIT=5
GRAPH_SIMILARITY_API_MAX_LIMIT=20
GRAPH_SIMILARITY_LLM_LIMIT=3
GRAPH_SIMILARITY_MIN_SCORE=0.3

# Demo/admin credentials
ADMIN_EMAIL=admin@threatflix.dev
ADMIN_PASSWORD=replace-before-production

# Analysis and API rate limits
ANALYSIS_COOLDOWN_MS=120000
ANALYSIS_EVENT_THRESHOLD=5
ANALYSIS_MAX_PER_MINUTE=5
ANALYSIS_GLOBAL_MAX_PER_MINUTE=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
