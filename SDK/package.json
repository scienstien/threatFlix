{
  "name": "@scienstien/threatflix-sdk",
  "version": "1.1.0",
  "description": "Thin TypeScript SDK for delivering canonical security telemetry to ThreatFlix",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scienstien/threatFlix.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "INTEGRATION_GUIDE.md"
  ],
  "scripts": {
    "build": "bun run tsc",
    "dev": "bun run tsc --watch",
    "test": "bun test",
    "prepack": "bun run test && bun run build"
  },
  "keywords": [
    "security",
    "events",
    "logging",
    "sdk",
    "threatflix",
    "telemetry",
    "cybersecurity"
  ],
  "author": "ThreatFlix Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
