{
  "name": "@scienstien/threatflix-sdk",
  "version": "1.0.0",
  "description": "ThreatFlix SDK - Capture and send security events to your backend",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scienstien/threatFlix.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run tsc",
    "dev": "bun run tsc --watch",
    "test": "bun test",
    "prepublish": "bun run build"
  },
  "keywords": [
    "security",
    "events",
    "logging",
    "sdk",
    "threatflix"
  ],
  "author": "ThreatFlix Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
